{
  "name": "emergency-protocol-diagram",
  "private": true,
  "version": "0.1.0",
  "description": "Emergency protocol diagram full-stack monorepo with React client and Express API",
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace @emergency-protocol-diagram/client",
    "dev:server": "npm run dev --workspace @emergency-protocol-diagram/server",
    "build": "npm run build --workspaces",
    "postbuild": "rm -rf dist && mkdir -p dist && cp -R apps/client/dist/. dist/",
    "build:client": "npm run build --workspace @emergency-protocol-diagram/client",
    "build:server": "npm run build --workspace @emergency-protocol-diagram/server",
    "lint": "npm run lint --workspaces",
    "lint:client": "npm run lint --workspace @emergency-protocol-diagram/client",
    "lint:server": "npm run lint --workspace @emergency-protocol-diagram/server",
    "test": "npm run test --workspace @emergency-protocol-diagram/server -- --runInBand",
    "test:server": "npm run test --workspace @emergency-protocol-diagram/server -- --runInBand"
  },
  "engines": {
    "node": ">=20"
  }
}
