    "asthma": {
      "id": "asthma",
      "type": "action",
      "title": "אסטמה",
      "severity": "urgent",
      "content": {
        "treatment": [
          "השב את המטופל זקוף ואל תשכיב אם זה מחמיר את הנשימה",
