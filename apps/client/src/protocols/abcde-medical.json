    "post_seizure": {
      "id": "post_seizure",
      "type": "action",
      "title": "פוסט פרכוס/הרעלה",
      "severity": "urgent",
      "content": {
        "treatment": [
          "הערך מחדש הכרה, נתיב אוויר ונשימה",
          "בצע סקשיין אם יש רוק, קיא או הפרשות",
          "אם המטופל נושם ואין חשד לטראומה - מנח החלמה",
          "תן חמצן לפי מצב נשימתי ומדדים",
          "חפש גורם הפיך וסימני החמרה, והמשך ל-B ול-C בסכמה"
        ],
        "sources": [
          {
            "label": "מד\"א - פרוטוקולים והנחיות לטיפול בנפגעי טראומה ובמצבי חירום (מהדורה ציבורית 2016)",
